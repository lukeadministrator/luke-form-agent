# Copy to .env for local dev:  cp .env.example .env
#
# Default brain = Groq (free, email signup): https://console.groq.com/keys
# Production (Render): set GROQ_API_KEY in the dashboard.
# Local dev: set GROQ_API_KEY here, OR leave all blank and run Ollama locally
#            (ollama pull qwen2.5:7b) — the app falls back to it.

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Alternatives (optional):
# GEMINI_API_KEY=        # blocked for managed/Workspace domains
# GEMINI_MODEL=gemini-2.0-flash
OLLAMA_MODEL=qwen2.5:7b
